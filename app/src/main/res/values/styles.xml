<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="button_base" parent="Widget.Material3.Button">
        <item name="android:gravity">center_vertical|center_horizontal</item>
        <item name="android:textColor">@color/white</item>
        <!--        <item name="android:shadowColor">#FF000000</item>-->
        <!--        <item name="android:shadowDx">0</item>-->
        <!--        <item name="android:shadowDy">-1</item>-->
        <!--        <item name="android:shadowRadius">0.2</item>-->
        <item name="android:textSize">@dimen/btn_text_size</item>
        <item name="android:textStyle">bold</item>
        <item name="android:width">@dimen/btn_size</item>
        <item name="android:height">@dimen/btn_size</item>
        <item name="android:background">@drawable/circle_button</item>
        <item name="shapeAppearanceOverlay">@style/ButtonRounded</item>

    </style>

    <style name="imageview_base">
        <item name="android:width">@dimen/btn_size</item>
        <item name="android:height">@dimen/btn_size</item>
        <item name="shapeAppearanceOverlay">@style/ButtonRounded</item>

    </style>

    <style name="Widget.Button" parent="button_base">
        <!--        <item name="android:shadowColor">#FF000000</item>-->
        <!--        <item name="android:shadowDx">0</item>-->
        <!--        <item name="android:shadowDy">-1</item>-->
        <!--        <item name="android:shadowRadius">0.2</item>-->
        <item name="android:backgroundTint">@color/number_button</item>
    </style>

    <style name="Widget.Button.Action" parent="button_base">
        <!--        <item name="android:shadowColor">#FF000000</item>-->
        <!--        <item name="android:shadowDx">0</item>-->
        <!--        <item name="android:shadowDy">-1</item>-->
        <!--        <item name="android:shadowRadius">0.2</item>-->
        <item name="android:backgroundTint">@color/action_button</item>
        <item name="android:textSize">@dimen/btn_action_text_size</item>
    </style>

    <style name="ButtonRounded">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSizeTopLeft">@dimen/btn_halfsize</item>
        <item name="cornerSizeBottomLeft">@dimen/btn_halfsize</item>
        <item name="cornerSizeTopRight">@dimen/btn_halfsize</item>
        <item name="cornerSizeBottomRight">@dimen/btn_halfsize</item>
        <item name="cornerSize">50%</item>
    </style>

</resources>